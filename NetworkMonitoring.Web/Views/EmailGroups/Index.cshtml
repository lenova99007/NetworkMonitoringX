@model IEnumerable<NetworkMonitoring.Shared.Models.EmailGroup>
<h2>Email Groups</h2><p><a class='btn btn-primary' asp-action='Create'>Create</a></p>
<table class='table'>
    <thead><tr><th>ID</th><th>Name</th><th>From</th><th>To</th><th></th></tr></thead>
    <tbody>
        @foreach (var e in Model)
        {
            <tr><td>@e.EmailGroupId</td><td>@e.EmailGroupsName</td><td>@e.EmailFrom</td><td>@e.EmailTO</td><td><a asp-action='Edit' asp-route-id='@e.EmailGroupId' class='btn btn-sm btn-secondary'>Edit</a> <a asp-action='Delete' asp-route-id='@e.EmailGroupId' class='btn btn-sm btn-danger'>Delete</a></td></tr>
}
    </tbody>
</table>
