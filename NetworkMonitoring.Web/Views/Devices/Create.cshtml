@model NetworkMonitoring.Shared.Models.Device
<h2>Create Device</h2>
<form method="post" asp-action="Create">
    <input asp-for="DeviceName" class="form-control mb-2" placeholder="Name" />
    <input asp-for="IPAddress" class="form-control mb-2" placeholder="IP" />
    <select asp-for="DeviceTypeId" class="form-control mb-2">@foreach (var t in ViewBag.Types)
    {<option value='@t.DeviceTypeId'>@t.TypeName</option>}</select>
    <select asp-for="LocationId" class="form-control mb-2">@foreach (var l in ViewBag.Locations)
    {<option value='@l.LocationId'>@l.LocationName_En</option>}</select>
    <button class="btn btn-primary">Save</button>
</form>
